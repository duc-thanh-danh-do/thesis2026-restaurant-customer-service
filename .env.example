DATABASE_URL="postgresql://postgres:postgres@localhost:5432/phygital_dining"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/phygital_dining"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"
STAFF_SESSION_COOKIE="staff_session"
STAFF_SESSION_SECRET="change-this-to-a-long-random-secret"
STAFF_SESSION_TTL_SECONDS="43200"
# Optional. Defaults to true in production and false otherwise.
# STAFF_SESSION_COOKIE_SECURE="false"
STAFF_LOGIN_MAX_ATTEMPTS="5"
STAFF_LOGIN_WINDOW_SECONDS="900"
# Development only; production staff accounts must have password hashes.
ALLOW_DEV_DEFAULT_STAFF_PASSWORD="false"
# Seed scripts require an explicit password unless this is true. Never enable it
# for production or a persistent/shared database.
ALLOW_INSECURE_SEED_PASSWORD="false"
STAFF_DEFAULT_PASSWORD="replace-with-a-strong-development-password"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Only enable these behind a proxy that overwrites inbound forwarding headers.
TRUST_PROXY_HEADERS="false"
TRUSTED_APP_HOSTS="localhost:3000"
