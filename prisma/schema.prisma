generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id            Int                       @id @default(autoincrement())
  name          String                    @db.VarChar(255)
  description   String?                   @db.Text
  address       String?                   @db.VarChar(255)
  createdAt     DateTime?                 @map("created_at")
  updatedAt     DateTime?                 @map("updated_at")
  tables        RestaurantTable[]
  diningSessions DiningSession[]
  sessions      CustomerSession[]
  staffUsers    StaffUser[]
  menuItems     MenuItem[]
  knowledgeBase RestaurantKnowledgeBase[]
  knowledgeDocuments KnowledgeDocument[]
  handoverRules HandoverRule[]
  instructionVersions AiInstructionVersion[]

  ingredientCatalogs IngredientCatalog[]
  dietaryCatalogs    DietaryCatalog[]

  @@map("restaurants")
}

model RestaurantTable {
  id           Int               @id @default(autoincrement())
  restaurantId Int               @map("restaurant_id")
  tableNumber  String            @map("table_number") @db.VarChar(50)
  qrCodeToken  String            @unique @map("qr_code_token") @db.VarChar(255)
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime?         @map("created_at")
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  diningSessions DiningSession[]
  sessions     CustomerSession[]

  @@map("restaurant_tables")
}

model DiningSession {
  id               Int                @id @default(autoincrement())
  restaurantId     Int                @map("restaurant_id")
  tableId          Int                @map("table_id")
  status           String             @db.VarChar(50)
  startedAt        DateTime?          @map("started_at")
  endedAt          DateTime?          @map("ended_at")
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  table            RestaurantTable    @relation(fields: [tableId], references: [id])
  customerSessions CustomerSession[]

  @@map("dining_sessions")
}

model CustomerSession {
  id               Int                @id @default(autoincrement())
  diningSessionId  Int                @map("dining_session_id")
  restaurantId     Int                @map("restaurant_id")
  tableId          Int                @map("table_id")
  sessionToken     String             @unique @map("session_token") @db.VarChar(255)
  status           String             @db.VarChar(50)
  startedAt        DateTime?          @map("started_at")
  endedAt          DateTime?          @map("ended_at")
  diningSession    DiningSession      @relation(fields: [diningSessionId], references: [id])
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  table            RestaurantTable    @relation(fields: [tableId], references: [id])
  chatMessages     ChatMessage[]
  orders           Order[]
  customerRequests CustomerRequest[]
  aiResponseLogs   AiResponseLog[]

  @@map("customer_sessions")
  @@index([restaurantId])
  @@index([tableId, status])
  @@index([diningSessionId])
}

model StaffUser {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  name         String     @db.VarChar(255)
  email        String     @unique @db.VarChar(255)
  passwordHash String?    @map("password_hash") @db.VarChar(255)
  role         String?    @db.VarChar(50)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime?  @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  uploadedKnowledgeDocuments KnowledgeDocument[]

  @@map("staff_users")
}

model ChatMessage {
  id                     Int             @id @default(autoincrement())
  sessionId              Int             @map("session_id")
  senderType             String          @map("sender_type") @db.VarChar(50)
  messageContent         String          @map("message_content") @db.Text
  createdAt              DateTime?       @map("created_at")
  session                CustomerSession @relation(fields: [sessionId], references: [id])
  customerAiResponseLogs AiResponseLog[] @relation("AiCustomerMessageLog")
  aiResponseLogs         AiResponseLog[] @relation("AiMessageLog")

  @@map("chat_messages")
  @@index([sessionId, id])
}

model CustomerRequest {
  id          Int             @id @default(autoincrement())
  sessionId   Int             @map("session_id")
  requestType String          @map("request_type") @db.VarChar(100)
  status      String          @db.VarChar(50)
  description String?         @db.Text
  createdAt   DateTime?       @map("created_at")
  resolvedAt  DateTime?       @map("resolved_at")
  session     CustomerSession @relation(fields: [sessionId], references: [id])

  @@map("customer_requests")
  @@index([sessionId, createdAt])
}

model MenuItem {
  id                Int                 @id @default(autoincrement())
  restaurantId      Int                 @map("restaurant_id")
  name              String              @db.VarChar(255)
  description       String?             @db.Text
  category          String?             @db.VarChar(100)
  price             Decimal             @db.Decimal(10, 2)
  ingredients       String?             @db.Text
  dietary           String?             @db.Text
  imageUrl          String?             @map("image_url") @db.VarChar(500)
  isAvailable       Boolean             @default(true) @map("is_available")
  createdAt         DateTime?           @map("created_at")
  updatedAt         DateTime?           @map("updated_at")
  restaurant        Restaurant          @relation(fields: [restaurantId], references: [id])
  menuItemAllergens MenuItemAllergen[]

  @@map("menu_items")
  @@index([restaurantId, isAvailable])
}

model Allergen {
  id                Int                 @id @default(autoincrement())
  name              String              @unique @db.VarChar(100)
  description       String?             @db.Text
  menuItemAllergens MenuItemAllergen[]

  @@map("allergens")
}

model MenuItemAllergen {
  menuItemId Int      @map("menu_item_id")
  allergenId Int      @map("allergen_id")
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  allergen   Allergen @relation(fields: [allergenId], references: [id])

  @@id([menuItemId, allergenId])
  @@map("menu_item_allergens")
}

model RestaurantKnowledgeBase {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  title        String     @db.VarChar(255)
  content      String     @db.Text
  category     String?    @db.VarChar(100)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime?  @map("created_at")
  updatedAt    DateTime?  @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("restaurant_knowledge_base")
  @@index([restaurantId, isActive])
}

model KnowledgeDocument {
  id               Int                      @id @default(autoincrement())
  restaurantId     Int                      @map("restaurant_id")
  uploadedByStaffId Int?                    @map("uploaded_by_staff_id")
  originalFilename String                   @map("original_filename") @db.VarChar(255)
  mimeType         String                   @map("mime_type") @db.VarChar(255)
  fileSize         Int                      @map("file_size")
  status           String                   @db.VarChar(50)
  publicationStatus String                  @default("DRAFT") @map("publication_status") @db.VarChar(50)
  isActive         Boolean                  @default(true) @map("is_active")
  errorMessage     String?                  @map("error_message") @db.Text
  validationResults Json?                   @map("validation_results")
  validatedAt      DateTime?                @map("validated_at")
  approvedAt       DateTime?                @map("approved_at")
  publishedAt      DateTime?                @map("published_at")
  createdAt        DateTime?                @map("created_at")
  updatedAt        DateTime?                @map("updated_at")
  restaurant       Restaurant               @relation(fields: [restaurantId], references: [id])
  uploadedBy       StaffUser?               @relation(fields: [uploadedByStaffId], references: [id])
  chunks           KnowledgeDocumentChunk[]

  @@index([restaurantId, status, publicationStatus, isActive])
  @@index([uploadedByStaffId])
  @@map("knowledge_documents")
}

model KnowledgeDocumentChunk {
  id         Int               @id @default(autoincrement())
  documentId Int               @map("document_id")
  chunkIndex Int               @map("chunk_index")
  content    String            @db.Text
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime?         @map("created_at")
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("knowledge_document_chunks")
}

model AiResponseLog {
  id                Int              @id @default(autoincrement())
  sessionId         Int?             @map("session_id")
  customerMessageId Int?             @map("customer_message_id")
  aiMessageId       Int?             @map("ai_message_id")
  modelName         String?          @map("model_name") @db.VarChar(100)
  retrievedContext  String?          @map("retrieved_context") @db.Text
  retrievedKnowledge Json?           @map("retrieved_knowledge")
  prompt            String?          @db.Text
  response          String?          @db.Text
  handoverRequired  Boolean          @default(false) @map("handover_required")
  handoverReason    String?          @map("handover_reason") @db.Text
  handoverRuleId    Int?             @map("handover_rule_id")
  instructionVersionId Int?          @map("instruction_version_id")
  createdAt         DateTime?        @map("created_at")
  session           CustomerSession? @relation(fields: [sessionId], references: [id])
  customerMessage   ChatMessage?     @relation("AiCustomerMessageLog", fields: [customerMessageId], references: [id])
  aiMessage         ChatMessage?     @relation("AiMessageLog", fields: [aiMessageId], references: [id])
  handoverRule      HandoverRule?    @relation(fields: [handoverRuleId], references: [id])
  instructionVersion AiInstructionVersion? @relation(fields: [instructionVersionId], references: [id])

  @@index([instructionVersionId])
  @@index([sessionId, id])
  @@map("ai_response_logs")
}

model AiInstructionVersion {
  id                Int             @id @default(autoincrement())
  restaurantId      Int             @map("restaurant_id")
  version           Int
  status            String          @db.VarChar(50)
  rolePrompt        String          @map("role_prompt") @db.Text
  handoverPrompt    String          @map("handover_prompt") @db.Text
  releaseNotes      String          @map("release_notes") @db.Text
  validationResults Json?           @map("validation_results")
  testResults       Json?           @map("test_results")
  createdByStaffId  Int             @map("created_by_staff_id")
  approvedByStaffId Int?            @map("approved_by_staff_id")
  validatedAt       DateTime?       @map("validated_at")
  testedAt          DateTime?       @map("tested_at")
  approvedAt        DateTime?       @map("approved_at")
  publishedAt       DateTime?       @map("published_at")
  archivedAt        DateTime?       @map("archived_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  restaurant        Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  responseLogs      AiResponseLog[]

  @@unique([restaurantId, version])
  @@index([restaurantId, status, updatedAt])
  @@index([createdByStaffId])
  @@index([approvedByStaffId])
  @@map("ai_instruction_versions")
}

model HandoverRule {
  id              Int             @id @default(autoincrement())
  restaurantId    Int             @map("restaurant_id")
  name            String          @db.VarChar(255)
  category        String          @db.VarChar(100)
  requestType     String          @map("request_type") @db.VarChar(100)
  keywords        Json
  responseMessage String?         @map("response_message") @db.Text
  priority        Int             @default(0)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime?       @map("created_at")
  updatedAt       DateTime?       @map("updated_at")
  restaurant      Restaurant      @relation(fields: [restaurantId], references: [id])
  aiResponseLogs  AiResponseLog[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive, priority])
  @@map("handover_rules")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  restaurantId Int?  @map("restaurant_id")
  actorStaffId Int?   @map("staff_user_id")
  actorType String   @map("actor_type") @db.VarChar(50)
  action    String   @db.VarChar(100)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([restaurantId, createdAt])
  @@index([actorStaffId])
  @@map("audit_logs")
}

model Order {
  id           Int             @id @default(autoincrement())
  sessionId    Int             @map("session_id")
  status       String          @db.VarChar(50) 
  total        Decimal         @db.Decimal(10, 2)
  createdAt    DateTime?       @default(now()) @map("created_at")
  session      CustomerSession @relation(fields: [sessionId], references: [id])
  orderItems   OrderItem[]

  @@map("orders")
  @@index([sessionId, status, createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  name      String  @db.VarChar(255)
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
  @@index([orderId])
}

model IngredientCatalog {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  name         String     @db.VarChar(100)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  @@map("ingredient_catalog")
}

model DietaryCatalog {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  name         String     @db.VarChar(100)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  @@map("dietary_catalog")
}
